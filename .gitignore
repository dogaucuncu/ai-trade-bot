# ══════════════════════════════════════════════════════════════════════
# AI Trade Bot — .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── Secrets & Environment ─────────────────────────────────────────────
# CRITICAL: Never commit real API keys or credentials
.env
config/.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.Python
develop-eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# ── Virtual Environments ─────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.conda/

# ── IDE / Editors ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject

# ── Data & Databases ─────────────────────────────────────────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.bak*
*.db-journal
*.db-wal
*.db-shm
# DB backups (e.g. tradebot.db.bak-20260623-141927) — keep local, never commit
*.db.bak*

# ── Log Files ─────────────────────────────────────────────────────────
logs/
*.log
*.log.*
*.log.zip

# ── ML Model Artifacts ───────────────────────────────────────────────
# Eğitilmiş modeller büyük olabilir; gerekirse Git LFS kullanın
models/**/*.pt
models/**/*.pth
models/**/*.npz
models/**/*.npy
# NOT: models/ altındaki metadata.json dosyaları takip edilebilir

# ── Backtest Results ──────────────────────────────────────────────────
backtest/results/*.html
backtest/results/*.json
# Scratch run logs/output (prefixed with _)
backtest/results/_*
*.out

# ── Jupyter Notebooks ─────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Testing & Coverage ───────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── Distribution / Packaging ─────────────────────────────────────────
*.tar.gz
*.zip
*.rar
*.7z

# ── OS Generated Files ───────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── Misc ──────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.gemini/

# ── Graphify (knowledge graph output) ────────────────────────────────
graphify-out/

# ── Claude Code ───────────────────────────────────────────────────────
.claude/settings.local.json
