# ============================================================
# AI Trade Bot — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real credentials.
#   cp .env.example .env
# NEVER commit the .env file to version control.
# ============================================================

# --- Trading Mode ---
TRADING_MODE=paper            # paper | live
INITIAL_CAPITAL=50.0          # Total starting capital in USD

# --- Capital Allocation ---
CRYPTO_ALLOCATION=0.75        # 75% → ~$37.50 for altcoins
STOCK_ALLOCATION=0.25         # 25% → ~$12.50 for equities
MIN_TRADE_CRYPTO=5.0          # Binance minimum order ~$5-$10
MIN_TRADE_STOCK=5.0           # Alpaca fractional minimum
FRACTIONAL_SHARES=true        # Enable fractional shares (Alpaca)

# --- Binance (Crypto) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true          # Use testnet for paper trading

# --- Alpaca (US Stocks) ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true             # Use paper trading endpoint

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/tradebot.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- SMTP Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
SMTP_TO=recipient@example.com

# --- Sentiment risk gate (Claude-free, optional) ---
# A conservative news/sentiment filter applied before order execution. It only
# BLOCKS trades that fight strongly adverse news/mood; it never opens trades and
# makes NO LLM/Claude calls. Start in observation mode (GATE=false) to watch
# scores in the logs, then enable GATE=true once you trust it.
SENTIMENT_ENABLED=false       # master switch for the sentiment gate
SENTIMENT_GATE=false          # true = enforce vetoes; false = observe only
SENTIMENT_THRESHOLD=0.5       # |score| beyond which sentiment is "strong"
SENTIMENT_CACHE_TTL=1800      # per-symbol score cache, seconds (30 min)
CRYPTOPANIC_TOKEN=            # optional free CryptoPanic token (else uses RSS)

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# --- Dashboard ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
